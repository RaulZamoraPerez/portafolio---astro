---

<Layout title="Reconocimientos | Raul Zamora">
  <Navbar />
  <main class="honors-page">
    <div class="header-bg"></div>
    
    <div class="container">
      <div class="back-link">
        <a href="/">← Volver al inicio</a>
      </div>

      <header class="page-header">
        <h1 class="page-title">Muro de <span class="highlight">Honor</span></h1>
        <p class="page-subtitle">Premios, logros y certificaciones que avalan mi compromiso con el aprendizaje constante.</p>
      </header>

      <!-- Premios Section -->
      <section class="honors-section">
        <div class="section-label">
          <span class="dot" style="background: #FFD700"></span>
          <h2>Premios & Distinciones</h2>
        </div>
        <div class="honors-grid awards">
          {awards.map((item) => (
            <div class="honor-card award clickable" data-title={item.title} data-image={item.image} data-desc={item.desc} style={`--accent: ${item.color}`}>
              <div class="card-image-mini">
                {Array.isArray(item.thumbnail) ? (
                  <div class="thumbnail-collage">
                    {item.thumbnail.map(img => <img src={img} alt="" />)}
                  </div>
                ) : (
                  <img src={item.thumbnail} alt={item.title} loading="lazy" />
                )}
                <div class="image-overlay">
                  <span>Ver más</span>
                </div>
              </div>
              <div class="card-content-compact">
                <div class="header-mini">
                  <span class="card-icon" set:html={item.icon}></span>
                  <span class="card-date">{item.date}</span>
                </div>
                <h3 class="card-title-mini">{item.title}</h3>
                <p class="card-org-mini">{item.org}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Modal -->
      <div id="honor-modal" class="modal">
        <div class="modal-backdrop"></div>
        <div class="modal-content">
          <button class="modal-close">&times;</button>
          <div class="modal-body">
            <div class="modal-image-container">
              <img id="modal-img" src="" alt="" />
            </div>
            <div class="modal-info">
              <span id="modal-date" class="card-date"></span>
              <h2 id="modal-title"></h2>
              <p id="modal-desc"></p>
            </div>
          </div>
        </div>
      </div>


      <!-- Certificados Section -->
      <section class="honors-section">
        <div class="section-label">
          <span class="dot" style="background: #00D4FF"></span>
          <h2>Especializaciones & Certificaciones</h2>
        </div>
        <div class="honors-grid certs">
          {certificates.map((item) => (
            <div class="premium-cert-card" style={`--accent: ${item.color}`}>
              <div class="card-glow-bg"></div>
              <div class="card-border-glow"></div>
              
              <div class="cert-header">
                <div class="tech-badge">
                  {item.slug ? (
                    <img 
                      src={`https://cdn.simpleicons.org/${item.slug}/${item.color.replace('#', '')}`} 
                      alt={item.title}
                      width="48" 
                      height="48"
                    />
                  ) : (
                    <span class="custom-icon">{item.icon}</span>
                  )}
                </div>
                <div class="cert-meta">
                  <span class="cert-year">{item.date}</span>
                  <span class="cert-status">Verified</span>
                </div>
              </div>
              
              <div class="cert-body">
                <h3 class="cert-title">{item.title}</h3>
                <p class="cert-subtitle">{item.org}</p>
              </div>

              <div class="cert-footer">
                <a href={item.file} target="_blank" class="premium-btn">
                  <span>Validar Credencial</span>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3"/></svg>
                </a>
              </div>
            </div>
          ))}
        </div>
      </section>


      <!-- Tech Ecosystem Marquee -->
      <section class="honors-section marquee-section">
        <div class="section-label">
          <span class="dot" style="background: var(--cyan)"></span>
          <h2>Ecosistema Tecnológico</h2>
        </div>
        <p class="section-desc">Herramientas y tecnologías que domino y aplico en mis proyectos de ingeniería.</p>
        
        <div class="tech-marquee-container">
          <div class="marquee-track">
            {[...slugs, ...slugs].map((slug) => (
              <div class="tech-card-mini">
                <img 
                  src={`https://cdn.simpleicons.org/${slug}/white`} 
                  alt={slug}
                  loading="lazy"
                />
                <span>{slug}</span>
              </div>
            ))}
          </div>
        </div>
      </section>
    </div>
  </main>
</Layout>

<script>
  // Slugs for the marquee
  const slugs = [
    "typescript", "javascript", "dotnet", "csharp", "react", "laravel", 
    "nodedotjs", "express", "nextdotjs", "postgresql", "firebase", 
    "docker", "git", "github", "visualstudiocode", "figma", "android",
    "html5", "css3", "amazons3", "nginx", "vercel", "prisma"
  ];
</script>

<style>
  .honors-page {
    min-height: 100vh;
    padding: 8rem 2rem;
    position: relative;
    overflow-x: hidden;
  }

  .header-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 60vh;
    background: radial-gradient(circle at 50% 0%, rgba(0, 212, 255, 0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .back-link {
    margin-bottom: 2rem;
  }

  .back-link a {
    color: var(--cyan);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    opacity: 0.6;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .back-link a:hover {
    opacity: 1;
    transform: translateX(-5px);
  }

  .page-header {
    margin-bottom: 6rem;
    text-align: center;
  }

  .page-title {
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 900;
    margin-bottom: 1.5rem;
    color: var(--text-primary);
  }

  .highlight {
    background: linear-gradient(90deg, var(--cyan), #0099ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .page-subtitle {
    font-size: 1.2rem;
    color: var(--text-secondary);
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
    opacity: 0.8;
  }

  .honors-section {
    margin-bottom: 8rem;
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .section-label .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    box-shadow: 0 0 15px var(--accent, var(--cyan));
  }

  .section-label h2 {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  .honors-grid.awards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .honor-card.award.clickable {
    cursor: pointer;
    flex-direction: column;
    padding: 1rem;
    gap: 1rem;
    min-height: auto;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 24px;
    transition: all 0.4s ease;
  }

  .honor-card.award.clickable:hover {
    transform: translateY(-5px);
    background: rgba(255, 255, 255, 0.05);
    border-color: var(--accent);
  }

  .card-image-mini {
    width: 100%;
    height: 180px;
    position: relative;
    overflow: hidden;
    border-radius: 16px;
    background: #000;
  }

  .card-image-mini img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .thumbnail-collage {
    display: grid;
    grid-template-columns: 1fr 1fr;
    height: 100%;
    gap: 2px;
    background: rgba(255,255,255,0.1);
  }

  .thumbnail-collage img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .honor-card.award:hover .image-overlay {
    opacity: 1;
  }

  .card-content-compact {
    padding: 0.5rem;
  }

  .header-mini {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }

  .card-title-mini {
    font-size: 1.1rem;
    font-weight: 800;
    color: white;
    margin-bottom: 0.25rem;
  }

  .card-org-mini {
    font-size: 0.85rem;
    color: var(--cyan);
    font-weight: 600;
  }

  /* Modal Styles */
  .modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .modal.active {
    display: flex;
  }

  .modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(2, 6, 23, 0.9);
    backdrop-filter: blur(10px);
  }

  .modal-content {
    position: relative;
    background: #0f172a;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 32px;
    max-width: 1000px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    z-index: 2;
    animation: modal-in 0.4s cubic-bezier(0.23, 1, 0.32, 1);
  }

  @keyframes modal-in {
    from { opacity: 0; transform: scale(0.9) translateY(20px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  .modal-close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: rgba(255, 255, 255, 0.05);
    border: none;
    color: white;
    font-size: 2rem;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    cursor: pointer;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .modal-body {
    display: flex;
    gap: 2rem;
    padding: 2rem;
  }

  .modal-image-container {
    flex: 1.2;
    background: #000;
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .modal-image-container img {
    max-width: 100%;
    max-height: 70vh;
    object-fit: contain;
  }

  .modal-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;
  }

  .modal-info h2 {
    font-size: 2rem;
    font-weight: 800;
    color: white;
  }

  .modal-info p {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  /* Certificados Section Styles */
  .honors-grid.certs {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2.5rem;
  }

  .premium-cert-card {
    position: relative;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 24px;
    padding: 2rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .premium-cert-card:hover {
    transform: translateY(-8px);
    background: rgba(255, 255, 255, 0.04);
    border-color: var(--accent);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 
                0 0 20px -5px var(--accent);
  }

  .card-glow-bg {
    position: absolute;
    top: 0;
    right: 0;
    width: 150px;
    height: 150px;
    background: radial-gradient(circle at 100% 0%, var(--accent), transparent 70%);
    opacity: 0.1;
    filter: blur(30px);
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .premium-cert-card:hover .card-glow-bg {
    opacity: 0.25;
  }

  .cert-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .tech-badge {
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    filter: drop-shadow(0 0 10px var(--accent));
    transition: transform 0.4s ease;
  }

  .premium-cert-card:hover .tech-badge {
    transform: scale(1.1) rotate(5deg);
  }

  .tech-badge img {
    width: 56px;
    height: 56px;
    object-fit: contain;
  }

  /* Cool AI Pulse Effect */
  .premium-cert-card[style*="#74aa9c"] .tech-badge img {
    animation: ai-pulse 3s infinite ease-in-out;
  }

  @keyframes ai-pulse {
    0%, 100% { filter: drop-shadow(0 0 5px #74aa9c) brightness(1); }
    50% { filter: drop-shadow(0 0 20px #74aa9c) brightness(1.3); }
  }

  .cert-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.4rem;
  }

  .cert-year {
    font-size: 1.2rem;
    font-weight: 800;
    color: white;
  }

  .cert-status {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #10b981;
    background: rgba(16, 185, 129, 0.1);
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
  }

  .cert-body {
    flex: 1;
  }

  .cert-title {
    font-size: 1.25rem;
    font-weight: 800;
    color: white;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .cert-subtitle {
    font-size: 0.9rem;
    color: var(--text-secondary);
    font-weight: 500;
  }

  .premium-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    padding: 0.8rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    color: white;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 700;
    transition: all 0.3s ease;
  }

  .premium-btn:hover {
    background: var(--accent);
    color: #020617;
    border-color: var(--accent);
    box-shadow: 0 0 20px var(--accent);
  }

  .section-desc {
    color: var(--text-secondary);
    margin-bottom: 2rem;
    font-size: 1.1rem;
    opacity: 0.8;
  }

  /* Tech Marquee */
  .tech-marquee-container {
    width: 100%;
    overflow: hidden;
    padding: 2rem 0;
    mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
  }

  .marquee-track {
    display: flex;
    gap: 1.5rem;
    width: max-content;
    animation: scroll 40s linear infinite;
  }

  .tech-card-mini {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 16px;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    transition: all 0.3s ease;
  }

  .tech-card-mini:hover {
    background: rgba(255, 255, 255, 0.08);
    transform: translateY(-5px);
    border-color: var(--cyan);
  }

  .tech-card-mini img {
    width: 24px;
    height: 24px;
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }

  .tech-card-mini:hover img {
    opacity: 1;
  }

  .tech-card-mini span {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-secondary);
    text-transform: capitalize;
  }

  @keyframes scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media (max-width: 900px) {
    .modal-body { flex-direction: column; }
    .modal-content { border-radius: 20px; }
  }

  @media (max-width: 768px) {
    .honors-grid { grid-template-columns: 1fr; }
    .page-title { font-size: 2.8rem; }
    .honor-card { padding: 2rem; }
    .honors-grid.awards { grid-template-columns: 1fr; }
    .honors-grid.certs { grid-template-columns: 1fr; }
  }
</style>

<script>
  const modal = document.getElementById('honor-modal');
  const modalImg = document.getElementById('modal-img') as HTMLImageElement;
  const modalTitle = document.getElementById('modal-title');
  const modalDesc = document.getElementById('modal-desc');
  const modalDate = document.getElementById('modal-date');
  const closeBtn = document.querySelector('.modal-close');
  const backdrop = document.querySelector('.modal-backdrop');

  function openModal(data: any) {
    if (!modal || !modalImg || !modalTitle || !modalDesc || !modalDate) return;
    
    modalImg.src = data.image;
    modalTitle.textContent = data.title;
    modalDesc.textContent = data.desc;
    modalDate.textContent = data.date;
    
    modal.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal?.classList.remove('active');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.honor-card.award.clickable').forEach(card => {
    card.addEventListener('click', () => {
      const data = {
        title: card.getAttribute('data-title'),
        image: card.getAttribute('data-image'),
        desc: card.getAttribute('data-desc'),
        date: card.querySelector('.card-date')?.textContent
      };
      openModal(data);
    });
  });

  closeBtn?.addEventListener('click', closeModal);
  backdrop?.addEventListener('click', closeModal);

  // Close on ESC
  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>

