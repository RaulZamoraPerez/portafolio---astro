    id: "NMEBP9UF",
    image: "https://learn.microsoft.com/training/achievements/work-with-variable-data-csharp-social.png",
    url: "https://learn.microsoft.com/es-mx/users/ZAMORAPEREZRAULEMMANUEL-8395/achievements/NMEBP9UF"
