const msLearn = [
  {
    title: "Arquitectura de Azure",
    id: "37MRRZDH",
    image: "https://learn.microsoft.com/training/achievements/describe-core-architectural-components-of-azure-social.png",
    url: "https://learn.microsoft.com/es-mx/users/ZAMORAPEREZRAULEMMANUEL-8395/achievements/37MRRZDH"
  },
  {
    title: "Métodos en C#",
    id: "HZVPLEH8",
    image: "https://learn.microsoft.com/training/achievements/create-csharp-methods-social.png",
    url: "https://learn.microsoft.com/es-mx/users/ZAMORAPEREZRAULEMMANUEL-8395/achievements/HZVPLEH8"
  },
  {
