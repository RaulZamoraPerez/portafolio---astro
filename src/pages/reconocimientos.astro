const slugs = [
  "typescript", "javascript", "dotnet", "csharp", "react", "laravel", 
  "nodedotjs", "express", "nextdotjs", "postgresql", "firebase", 
  "docker", "git", "github", "visualstudiocode", "figma", "android",
  "html5", "css3", "amazons3", "nginx", "vercel", "prisma"
