---
interface Props {
  name: string;
  title: string;
  handle: string;
  status: string;
  contactText: string;
  avatarUrl: string;
  behindGlowColor?: string;
  innerGradient?: string;
}

const { 
  name, 
  title, 
  handle, 
  status, 
  contactText, 
  avatarUrl,
  behindGlowColor = "rgba(0, 212, 255, 0.5)",
  innerGradient = "linear-gradient(145deg, rgba(96, 73, 110, 0.3) 0%, rgba(113, 196, 255, 0.2) 100%)"
} = Astro.props;
---

<div class="profile-card-container" style={`--glow-color: ${behindGlowColor}`}>
  <div class="glow-layer"></div>
  <div class="card-inner" style={`background: ${innerGradient}`}>
    <div class="card-pattern"></div>
    
    <div class="card-content">
      <div class="status-badge">
        <span class="status-dot"></span>
        {status}
      </div>

      <div class="avatar-wrapper">
        <img src={avatarUrl} alt={name} class="avatar-img" />
      </div>

      <div class="user-info">
        <h3 class="user-name">{name}</h3>
        <p class="user-title">{title}</p>
        <span class="user-handle">@{handle}</span>
      </div>

      <a href="#contacto" class="contact-btn">
        {contactText}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</div>

<style>
  .profile-card-container {
    position: relative;
    width: 280px;
    height: 400px;
    perspective: 1000px;
    z-index: 1;
  }

  .glow-layer {
    position: absolute;
    inset: -20px;
    background: var(--glow-color);
    filter: blur(40px);
    opacity: 0.3;
    border-radius: 40px;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }

  .profile-card-container:hover .glow-layer {
    opacity: 0.6;
  }

  .card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 32px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    overflow: hidden;
    backdrop-filter: blur(20px);
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2rem 1.5rem;
    transition: transform 0.1s ease;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
  }

  .card-pattern {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px);
    background-size: 20px 20px;
    opacity: 0.3;
    pointer-events: none;
  }

  .card-content {
    position: relative;
    z-index: 2;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    height: 100%;
  }

  .status-badge {
    background: rgba(0, 0, 0, 0.3);
    padding: 0.4rem 0.8rem;
    border-radius: 100px;
    font-size: 0.7rem;
    font-weight: 700;
    color: #fff;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    margin-bottom: 2rem;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    background: #00e676;
    border-radius: 50%;
    box-shadow: 0 0 10px #00e676;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { opacity: 1; }
    50% { opacity: 0.4; }
    100% { opacity: 1; }
  }

  .avatar-wrapper {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    padding: 4px;
    background: linear-gradient(135deg, var(--cyan) 0%, #0099ff 100%);
    margin-bottom: 1.5rem;
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
  }

  .avatar-img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid #1a1a1a;
  }

  .user-info {
    margin-bottom: auto;
  }

  .user-name {
    font-size: 1.25rem;
    font-weight: 800;
    color: #fff;
    margin-bottom: 0.25rem;
  }

  .user-title {
    font-size: 0.85rem;
    color: var(--cyan);
    font-weight: 600;
    margin-bottom: 0.2rem;
  }

  .user-handle {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.4);
    font-family: var(--font-code);
  }

  .contact-btn {
    width: 100%;
    padding: 0.8rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    color: #fff;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    transition: all 0.3s ease;
  }

  .contact-btn:hover {
    background: #fff;
    color: #000;
    transform: translateY(-2px);
  }
</style>

<script>
  // Simple Tilt Effect
  const cards = document.querySelectorAll('.profile-card-container');
  
  cards.forEach(card => {
    const inner = card.querySelector('.card-inner') as HTMLElement;
    
    card.addEventListener('mousemove', (e: any) => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      
      const rotateX = (y - centerY) / 10;
      const rotateY = (centerX - x) / 10;
      
      inner.style.transform = `rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
    });
    
    card.addEventListener('mouseleave', () => {
      inner.style.transform = 'rotateX(0deg) rotateY(0deg)';
    });
  });
</script>
