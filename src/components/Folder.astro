---
interface Props {
  size?: number;
  color?: string;
  className?: string;
}

const { size = 1, color = "#5227FF", className = "" } = Astro.props;

const papers = [
  { label: "Certificado Digyto", icon: "🏆", link: "/reconocimientos/certifcados/Raul Emmanuel Zamora Pérez-1.pdf" },
  { label: "Nacional Mérida", icon: "🥇", link: "#" },
  { label: "English Academy", icon: "🎓", link: "#" }
];
---

<div class={`folder-container ${className}`} style={`--size: ${size}; --color: ${color};`}>
  <div class="folder" id="interactive-folder">
    <!-- Back part of the folder -->
    <div class="folder-back">
      <div class="folder-tab"></div>
    </div>
    
    <!-- Paper content inside -->
    <div class="folder-papers">
      {papers.map((paper, i) => (
        <a href={paper.link} target="_blank" class={`paper paper-${i+1}`}>
          <div class="paper-content">
            <div class="paper-icon-svg">
               <span style="font-size: 1.4rem;">{paper.icon}</span>
            </div>
            <span class="tech-tag">{paper.label}</span>
          </div>
        </a>
      ))}
    </div>

    <!-- Front flap -->
    <div class="folder-front">
      <div class="folder-logo">
        <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 384 512">
          <path fill="currentColor" d="M97.12 362.63c-8.69-8.69-4.16-6.24-25.12-11.85c-9.51-2.55-17.87-7.45-25.43-13.32L1.2 448.7c-4.39 10.77 3.81 22.47 15.43 22.03l52.69-2.01L105.56 507c8 8.44 22.04 5.81 26.43-4.96l52.05-127.62c-10.84 6.04-22.87 9.58-35.31 9.58c-19.5 0-37.82-7.59-51.61-21.37M382.8 448.7l-45.37-111.24c-7.56 5.88-15.92 10.77-25.43 13.32c-21.07 5.64-16.45 3.18-25.12 11.85c-13.79 13.78-32.12 21.37-51.62 21.37c-12.44 0-24.47-3.55-35.31-9.58L252 502.04c4.39 10.77 18.44 13.4 26.43 4.96l36.25-38.28l52.69 2.01c11.62.44 19.82-11.27 15.43-22.03M263 340c15.28-15.55 17.03-14.21 38.79-20.14c13.89-3.79 24.75-14.84 28.47-28.98c7.48-28.4 5.54-24.97 25.95-45.75c10.17-10.35 14.14-25.44 10.42-39.58c-7.47-28.38-7.48-24.42 0-52.83c3.72-14.14-.25-29.23-10.42-39.58c-20.41-20.78-18.47-17.36-25.95-45.75c-3.72-14.14-14.58-25.19-28.47-28.98c-27.88-7.61-24.52-5.62-44.95-26.41c-10.17-10.35-25-14.4-38.89-10.61c-27.87 7.6-23.98 7.61-51.9 0c-13.89-3.79-28.72.25-38.89 10.61c-20.41 20.78-17.05 18.8-44.94 26.41c-13.89 3.79-24.75 14.84-28.47 28.98c-7.47 28.39-5.54 24.97-25.95 45.75c-10.17 10.35-14.15 25.44-10.42 39.58c7.47 28.36 7.48 24.4 0 52.82c-3.72 14.14.25 29.23 10.42 39.59c20.41 20.78 18.47 17.35 25.95 45.75c3.72 14.14 14.58 25.19 28.47 28.98C104.6 325.96 106.27 325 121 340c13.23 13.47 33.84 15.88 49.74 5.82a39.68 39.68 0 0 1 42.53 0c15.89 10.06 36.5 7.65 49.73-5.82M97.66 175.96c0-53.03 42.24-96.02 94.34-96.02s94.34 42.99 94.34 96.02s-42.24 96.02-94.34 96.02s-94.34-42.99-94.34-96.02"/>
        </svg>
      </div>
    </div>
  </div>
</div>

<style>
  .folder-container {
    --f-width: calc(180px * var(--size));
    --f-height: calc(130px * var(--size));
    --f-color: var(--color);
    
    display: flex;
    align-items: center;
    justify-content: center;
    perspective: 1000px;
    width: 100%;
    height: 100%;
  }

  .folder {
    position: relative;
    width: var(--f-width);
    height: var(--f-height);
    transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1);
    transform-style: preserve-3d;
    cursor: pointer;
    backface-visibility: hidden;
    will-change: transform;
  }

  .folder:hover {
    transform: rotateX(15deg) rotateY(-10deg);
  }

  .folder-back {
    position: absolute;
    inset: 0;
    background: var(--f-color);
    border-radius: 12px;
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.4);
    opacity: 0.95;
    transform: translateZ(0); /* Base layer */
  }

  .folder-tab {
    position: absolute;
    top: -15px;
    left: 0;
    width: 38%;
    height: 35px;
    background: var(--f-color);
    border-radius: 12px 12px 0 0;
    clip-path: polygon(0% 100%, 15% 0%, 85% 0%, 100% 100%);
  }

  .folder-front {
    position: absolute;
    inset: 0;
    background: var(--f-color);
    border-radius: 12px;
    transform-origin: bottom;
    transition: transform 0.5s cubic-bezier(0.23, 1, 0.32, 1);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transform: translateZ(25px); /* Ensure it's clearly in front */
    box-shadow: 
      inset 0 10px 20px rgba(255, 255, 255, 0.15),
      0 5px 15px rgba(0, 0, 0, 0.3);
    backface-visibility: hidden;
  }

  .folder:hover .folder-front,
  .folder.is-open .folder-front {
    transform: translateZ(25px) rotateX(-50deg);
  }

  .folder-logo {
    color: white;
    opacity: 0.6;
    width: 30%;
    height: 30%;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
  }

  .folder-papers {
    position: absolute;
    width: 92%;
    height: 92%;
    top: 4%;
    left: 4%;
    z-index: 5; /* Between back and front */
    transform-style: preserve-3d;
    transform: translateZ(10px); /* Mid layer */
  }

  .paper {
    position: absolute;
    inset: 0;
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 12px;
    transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 15px;
    backface-visibility: hidden;
    will-change: transform;
  }

  .paper-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
    width: 100%;
  }

  .paper-icon-svg {
    width: 32px;
    height: 32px;
    color: var(--f-color);
    filter: drop-shadow(0 0 8px var(--f-color));
  }

  .tech-tag {
    color: #1a1a1a;
    font-size: 0.6rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-align: center;
  }

  .flying-icon {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 32px;
    height: 32px;
    opacity: 0;
    pointer-events: none;
    transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    z-index: 20; /* Above everything when flying */
    filter: drop-shadow(0 0 8px currentColor);
  }

  .flying-icon svg {
    width: 100%;
    height: 100%;
  }

  .folder:hover .flying-icon {
    opacity: 1;
  }

  .fi-1 { --tx: -70px; --ty: -140px; --rot: -15deg; }
  .fi-2 { --tx: 70px;  --ty: -120px; --rot: 15deg;  }
  .fi-3 { --tx: -45px; --ty: -170px; --rot: 5deg;   }
  .fi-4 { --tx: 45px;  --ty: -160px; --rot: -5deg;  }

  .paper-1 { transform: translateY(0) translateZ(0); }
  .paper-2 { transform: translateY(-2px) rotate(-1deg) translateZ(1px); }
  .paper-3 { transform: translateY(-4px) rotate(1deg) translateZ(2px); }

  .folder:hover .paper-1, .folder.is-open .paper-1 { transform: translateY(-70px) rotate(-5deg) translateZ(10px); }
  .folder:hover .paper-2, .folder.is-open .paper-2 { transform: translateY(-110px) rotate(3deg) translateZ(20px); }
  .folder:hover .paper-3, .folder.is-open .paper-3 { transform: translateY(-150px) rotate(-2deg) translateZ(30px); }

  .folder:hover .fi-1, .folder.is-open .fi-1 { transform: translate(var(--tx), var(--ty)) rotate(var(--rot)); transition-delay: 0.1s; }
  .folder:hover .fi-2, .folder.is-open .fi-2 { transform: translate(var(--tx), var(--ty)) rotate(var(--rot)); transition-delay: 0.2s; }

  /* Glass effect for premium look */
  .folder-front::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.2) 0%, transparent 50%);
    border-radius: inherit;
    pointer-events: none;
  }
</style>

<script>
  const folders = document.querySelectorAll('.folder');
  folders.forEach(folder => {
    folder.addEventListener('click', (e) => {
      e.stopPropagation();
      folder.classList.toggle('is-open');
    });
  });

  // Close when clicking outside
  document.addEventListener('click', () => {
    folders.forEach(f => f.classList.remove('is-open'));
  });
</script>
