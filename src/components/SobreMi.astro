            </a>
            <a href="https://www.linkedin.com/in/raúl-emmanuel-zamora-perez-b94259376" target="_blank" rel="noopener" class="social-link-white" aria-label="LinkedIn">
              <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
            </a>
            <a href="/cv/Raul Emmanuel Zamora Perez CV.pdf" download class="social-link-white cv-link" aria-label="Descargar CV">
              <span class="cv-text">CV</span>
            </a>
          </div>
        </div>
      </div>

      <!-- 3. Stats (Tighter & Smaller) -->
      <div class="stats-compact-row">
        <div class="stat-item">
          <div class="stat-main">
            <span class="stat-num" data-target="1">0</span><span class="plus">+</span>
          </div>
          <p>Año Liderando</p>
        </div>
        <div class="stat-item">
          <div class="stat-main">
            <span class="stat-num" data-target="10">0</span><span class="plus">+</span>
          </div>
          <p>Sistemas Reales</p>
        </div>
        <div class="stat-item">
          <div class="stat-main">
            <span class="stat-num" data-target="20">0</span><span class="plus">+</span>
          </div>
          <p>Módulos Live</p>
        </div>
      </div>

      <!-- 4. Experience & Education (Better Grouped) -->
      <div class="bento-card main-content-card">
        <div class="content-split">
          <!-- Experience Column -->
          <div class="content-col exp-side">
            <div class="col-header">
