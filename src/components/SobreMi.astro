---
---
<section id="sobre-mi">
  <div class="section-container">
    <div class="section-label">
      <span class="label-line"></span>
      <span>Sobre mí</span>
      <span class="label-line"></span>
    </div>

    <div class="sobre-bento-grid">
      <!-- 1. Profile Photo (Smaller & Clean) -->
      <div class="bento-card profile-card">
        <div class="image-wrapper">
          <img src="/me/image.png" alt="Raul Emmanuel Zamora Perez" class="profile-img" />
        </div>
      </div>

      <!-- 2. Main Bio Card (Icons moved here) -->
      <div class="bento-card bio-card">
        <div class="bio-header">
          <div class="bio-title-area">
            <h2 class="section-title">
              Soluciones Digitales
              <span class="highlight-text">de Alto Impacto</span>
            </h2>
          </div>
          <div class="bio-animation-mini">
            <script src="https://unpkg.com/@dotlottie/player-component@latest/dist/dotlottie-player.mjs" type="module"></script>
            <dotlottie-player src="/animacion/animacion.json" background="transparent" speed="1" style="width: 200px; height: 200px;" loop autoplay></dotlottie-player>
          </div>
        </div>
        
        <p class="sobre-desc">
          <strong>Ingeniero en Desarrollo y Gestión de Software (Egresado 2026)</strong>. 
          Con experiencia práctica liderando el desarrollo de sistemas reales en producción. 
          Apasionado por construir soluciones tecnológicas de alto impacto, me adapto rápido a nuevos retos, 
          disfruto el trabajo en equipo y aprendo constantemente. Cuento con dominio de tecnologías full stack 
          modernas con enfoque en arquitecturas limpias y escalables.
        </p>

        <div class="bio-footer">
          <div class="info-row">
            <div class="info-pill">📍 Cuacnopalan, Puebla</div>
            <div class="info-pill">
              <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" style="margin-right: 4px; vertical-align: middle;">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
              </svg>
              +52 249 169 8546
            </div>
          </div>
          
          <div class="social-mini-bar">
            <a href="https://github.com/RaulZamoraPerez" target="_blank" rel="noopener" class="social-link-white" aria-label="GitHub">
              <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            </a>
            <a href="https://www.linkedin.com/in/raúl-emmanuel-zamora-perez-b94259376" target="_blank" rel="noopener" class="social-link-white" aria-label="LinkedIn">
              <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
            </a>
            <a href="/cv/Raul Emmanuel Zamora Perez CV.pdf" download class="social-link-white cv-link" aria-label="Descargar CV">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path d="M14 3v4a1 1 0 0 0 1 1h4"/><path d="M17 21H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7l5 5v11a2 2 0 0 1-2 2"/><path d="M11 12.5a1.5 1.5 0 0 0-3 0v3a1.5 1.5 0 0 0 3 0m2-4.5l1.5 6l1.5-6"/></g></svg>
            </a>
          </div>
        </div>
      </div>

      <!-- 3. Stats (Tighter & Smaller) -->
      <div class="stats-compact-row">
        <div class="stat-item">
          <div class="stat-main">
            <span class="stat-num" data-target="1">0</span><span class="plus">+</span>
          </div>
          <p>Año Liderando</p>
        </div>
        <div class="stat-item">
          <div class="stat-main">
            <span class="stat-num" data-target="10">0</span><span class="plus">+</span>
          </div>
          <p>Sistemas Reales</p>
        </div>
        <div class="stat-item">
          <div class="stat-main">
            <span class="stat-num" data-target="20">0</span><span class="plus">+</span>
          </div>
          <p>Módulos Live</p>
        </div>
      </div>

      <!-- 4. Experience & Education (Better Grouped) -->
      <div class="bento-card main-content-card">
        <div class="content-split">
          <!-- Experience Column -->
          <div class="content-col exp-side">
            <div class="col-header">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
              <span>Experiencia</span>
            </div>
            <div class="exp-items">
              <div class="exp-entry">
                <strong>Full Stack Engineer — Digyto Solutions</strong>
                <p>Arquitectura Clean · Multi-tenant · SAT Automation · .NET 8 & Angular 19</p>
              </div>
              <div class="exp-entry">
                <strong>Lead Web Developer — Portal UTTECAM</strong>
                <p>Sitio institucional · React TS · +20 módulos · Miles de usuarios</p>
              </div>
              <div class="exp-entry">
                <strong>Full Stack Developer — Teslo Shop</strong>
                <p>E-commerce premium · Docker · Gestión de Inventario · Next.js & PostgreSQL</p>
              </div>
              <div class="exp-entry">
                <strong>Full Stack Developer — MERN Task Manager</strong>
                <p>Gestor profesional · Autenticación robusta · Gestión de equipos · MongoDB & Redux</p>
              </div>
              <div class="more-projects">
                <a href="#proyectos" class="more-projects-link">
                  y muchos proyectos más... <span class="view-btn">Ver abajo</span>
                </a>
              </div>
            </div>
          </div>
          
          <div class="vertical-divider"></div>

          <!-- Education & Honors Column -->
          <div class="content-col honors-side">
            <div class="col-header">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <span>Formación & Logros</span>
            </div>
            <div class="edu-honors-list">
              <div class="list-group">
                <h5>Formación</h5>
                <p><strong>Ingeniería en Desarrollo y Gestión de Software</strong> · Titulación en proceso (2026) · UTTECAM</p>
                <p><strong>TSU Desarrollo y Gestión de Software Multiplataforma</strong> · UTTECAM</p>
                <p><strong>CBTis 254 — Tecnológico en Programación</strong> · Egreso: 2022</p>
              </div>
              <div class="list-group">
                <h5>Premios</h5>
                <p>Premio Estatal Juventud 2025 · Puebla</p>
                <p>Top 5 Nacional DGETI · Mérida 2022</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #sobre-mi {
    padding: 6rem 2rem;
    background: radial-gradient(circle at 100% 0%, rgba(0, 212, 255, 0.03) 0%, transparent 40%);
  }

  .section-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-label {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 3rem;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--cyan);
    opacity: 0.8;
  }

  .label-line {
    width: 40px;
    height: 1px;
    background: rgba(0, 212, 255, 0.3);
  }

  .sobre-bento-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 1.2rem;
  }

  .bento-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 24px;
    backdrop-filter: blur(20px);
    transition: all 0.4s ease;
  }

  .bento-card:hover {
    border-color: rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.03);
  }

  /* Spans */
  .profile-card { 
    grid-column: span 3; 
    grid-row: span 2; 
    padding: 0; /* Removed padding to make photo bigger */
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .bio-card { 
    grid-column: span 9; 
    grid-row: span 2; 
    padding: 2.2rem; 
    display: flex; 
    flex-direction: column; 
    justify-content: space-between; 
  }
  .stats-compact-row { 
    grid-column: span 12; 
    display: flex; 
    justify-content: space-around; 
    padding: 1.5rem;
    background: rgba(255,255,255,0.01);
    border-radius: 20px;
    border: 1px solid rgba(255,255,255,0.03);
    flex-wrap: wrap;
    gap: 1rem;
  }
  .main-content-card { grid-column: span 12; padding: 2.5rem; }

  /* Profile */
  .image-wrapper { 
    width: 100%; 
    height: 100%;
    position: relative; 
    overflow: hidden;
  }
  .profile-img { 
    width: 100%; 
    height: 100%; 
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .profile-card:hover .profile-img {
    transform: scale(1.05);
  }

  /* Bio Card */
  .bio-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 1.5rem; }
  .section-title { font-size: 2.2rem; font-weight: 900; line-height: 1.1; color: #fff; margin: 0; }
  .highlight-text { display: block; color: var(--cyan); }
  .sobre-desc { font-size: 1rem; color: var(--text-secondary); line-height: 1.6; margin: 1.5rem 0; max-width: 85%; }
  
  .bio-animation-mini {
    flex-shrink: 0;
    margin-right: -1rem;
    margin-top: -1.5rem;
  }

  .bio-footer { display: flex; justify-content: space-between; align-items: center; margin-top: auto; gap: 1rem; flex-wrap: wrap; }
  .info-row { display: flex; gap: 0.8rem; flex-wrap: wrap; }
  .info-pill { font-size: 0.75rem; color: #fff; opacity: 0.7; background: rgba(255,255,255,0.05); padding: 0.4rem 0.8rem; border-radius: 100px; border: 1px solid rgba(255,255,255,0.1); }

  .social-mini-bar { display: flex; gap: 0.8rem; align-items: center; }
  .social-link-white { 
    color: #fff; 
    opacity: 0.8; /* Increased default visibility */
    transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1); 
    display: flex; 
    align-items: center; 
    justify-content: center;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.05); /* Subtle button background */
    border: 1px solid rgba(255, 255, 255, 0.1);
    width: 42px;
    height: 42px;
    border-radius: 12px;
  }
  .social-link-white:hover { 
    opacity: 1; 
    transform: translateY(-3px); 
    background: rgba(0, 212, 255, 0.1);
    border-color: var(--cyan);
    color: var(--cyan);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
  }

  .cv-link {
    width: auto; /* Allow text to fit */
    padding: 0 1rem;
    border: 1px solid rgba(0, 212, 255, 0.3); /* Cyan border for prominence */
    background: rgba(0, 212, 255, 0.05);
  }

  .cv-text {
    font-size: 0.8rem;
    font-weight: 900;
    letter-spacing: 0.05em;
    color: var(--cyan);
  }

  /* Stats */
  .stat-item { text-align: center; flex: 1; min-width: 100px; }
  .stat-main { display: flex; align-items: baseline; justify-content: center; color: #fff; }
  .stat-num { font-size: 1.8rem; font-weight: 900; }
  .plus { color: var(--cyan); font-weight: 900; margin-left: 2px; }
  .stat-item p { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); font-weight: 800; margin-top: 0.2rem; }

  /* Split Content */
  .content-split { display: grid; grid-template-columns: 1fr auto 1fr; gap: 2.5rem; }
  .vertical-divider { width: 1px; background: rgba(255,255,255,0.05); height: 100%; }
  .col-header { display: flex; align-items: center; gap: 0.8rem; color: var(--cyan); font-weight: 800; text-transform: uppercase; font-size: 0.85rem; margin-bottom: 1.5rem; letter-spacing: 0.05em; }
  
  .exp-items { display: flex; flex-direction: column; gap: 1.2rem; }
  .exp-entry { margin-bottom: 1.5rem; }
  .exp-entry strong { display: block; color: var(--text-primary); font-size: 1rem; margin-bottom: 0.3rem; }
  .exp-entry p { color: var(--text-secondary); font-size: 0.85rem; opacity: 0.8; }

  .more-projects {
    margin-top: 0.5rem;
  }

  .more-projects-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    font-size: 0.75rem;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .more-projects-link:hover {
    color: var(--cyan);
  }

  .view-btn {
    color: var(--cyan);
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .edu-honors-list { display: flex; flex-direction: column; gap: 1.8rem; }
  .list-group h5 { font-size: 0.7rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.8rem; }
  .list-group p { font-size: 0.82rem; color: #fff; margin: 0.3rem 0; opacity: 0.9; line-height: 1.4; }
  .list-group p strong { color: var(--cyan); }

  @media (max-width: 1100px) {
    .section-title { font-size: 1.8rem; }
    .bio-animation-mini { transform: scale(0.8); }
  }

  @media (max-width: 1000px) {
    .sobre-bento-grid {
      display: grid;
      grid-template-columns: 1fr;
      grid-template-areas: 
        "photo"
        "bio"
        "stats"
        "main";
      gap: 1.5rem;
    }

    .bio-card { 
      grid-area: bio; 
      display: flex;
      flex-direction: column;
      position: relative;
    }
    .stats-compact-row { grid-area: stats; }
    .profile-card { 
      grid-area: photo; 
      height: 220px !important; 
      background: none !important;
      border: none !important;
      backdrop-filter: none !important;
      padding: 0 !important;
      overflow: visible;
    }
    .profile-img {
      object-position: center 20%; 
      border: 3px solid var(--cyan);
      border-radius: 24px;
      box-shadow: 0 10px 40px rgba(0, 212, 255, 0.2);
    }
    .image-wrapper {
      height: 100%;
      border-radius: 24px;
      overflow: hidden;
    }
    .main-content-card { grid-area: main; }

    .bento-card {
      padding: 1.2rem;
    }

    .bio-header {
      display: block; /* Normal flow */
    }

    .bio-animation-mini {
      position: absolute;
      top: 1.2rem;
      right: 1.2rem;
      margin: 0;
      z-index: 2;
    }

    .bio-animation-mini dotlottie-player {
      width: 80px !important;
      height: 80px !important;
    }

    .section-title {
      font-size: 1.8rem !important;
      text-align: left;
      padding-right: 60px; /* Space for the mini animation */
    }
  }

  @media (max-width: 900px) {
    .sobre-bento-grid { gap: 1rem; }
    .profile-card { grid-column: span 4; }
    .bio-card { grid-column: span 8; padding: 1.5rem; }
    .stat-num { font-size: 1.5rem; }
    .sobre-desc { font-size: 0.95rem; }
  }

  @media (max-width: 768px) {
    .sobre-bento-grid { display: flex; flex-direction: column; }
    .profile-card { padding: 2rem 1.5rem 1rem; order: 1; }
    .image-wrapper { max-width: 160px; }
    
    .bio-card { order: 2; padding: 2rem; text-align: center; }
    .bio-header { flex-direction: column; align-items: center; gap: 1rem; }
    .bio-animation-mini { margin: 0 auto; transform: none; order: -1; }
    .section-title { font-size: 2rem; }
    .sobre-desc { max-width: 100%; margin: 1.5rem 0 2rem; }
    
    .bio-footer { justify-content: center; }
    .info-row { justify-content: center; }
    .social-mini-bar { justify-content: center; width: 100%; margin-top: 1.5rem; }

    .stats-compact-row { order: 3; padding: 1.5rem 1rem; gap: 1.5rem; }
    .stat-item { min-width: 40%; }
    
    .main-content-card { order: 4; padding: 2rem 1.5rem; }
    .content-split { grid-template-columns: 1fr; gap: 2.5rem; }
    .vertical-divider { display: none; }
  }
</style>

<script>
  const statNums = document.querySelectorAll('.stat-num');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.target || '0');
        let current = 0;
        const duration = 2000;
        const startTime = performance.now();
        const animate = (currentTime: number) => {
          const elapsed = currentTime - startTime;
          const progress = Math.min(elapsed / duration, 1);
          el.textContent = Math.floor(progress * target).toString();
          if (progress < 1) requestAnimationFrame(animate);
        };
        requestAnimationFrame(animate);
        observer.unobserve(el);
      }
    });
  }, { threshold: 0.5 });
  statNums.forEach(num => observer.observe(num));
</script>
