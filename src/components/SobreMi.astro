---
<section id="sobre-mi">
  <div class="section-container">
    <div class="section-label">
      <span class="label-line"></span>
      <span>Sobre mí</span>
      <span class="label-line"></span>
    </div>

    <div class="sobre-bento-grid">
      <!-- 1. Profile Photo (Smaller & Clean) -->
      <div class="bento-card profile-card">
        <div class="image-wrapper">
          <img src="/me/image.png" alt="Raul Emmanuel Zamora Perez" class="profile-img" />
          <div class="image-inner-glow"></div>
        </div>
      </div>

      <!-- 2. Main Bio Card (Icons moved here) -->
      <div class="bento-card bio-card">
        <div class="bio-header">
          <div class="bio-title-area">
            <h2 class="section-title">
              Soluciones Digitales
              <span class="highlight-text">de Alto Impacto</span>
            </h2>
          </div>
          <div class="bio-animation-mini">
            <script src="https://unpkg.com/@dotlottie/player-component@latest/dist/dotlottie-player.mjs" type="module"></script>
            <dotlottie-player src="/animacion/animacion.json" background="transparent" speed="1" style="width: 200px; height: 200px;" loop autoplay></dotlottie-player>
          </div>
        </div>
        
        <p class="sobre-desc">
          <strong>Ingeniero en Desarrollo y Gestión de Software</strong> por la UT Tecamachalco (2026). 
          Especialista en liderar el ciclo de vida de sistemas en producción, desde arquitecturas limpias 
          (Clean Architecture) hasta interfaces de alto rendimiento.
        </p>

        <div class="bio-footer">
          <div class="info-row">
            <div class="info-pill">📍 Puebla, MX</div>
            <div class="info-pill">📱 +52 249 169 8546</div>
          </div>
          
          <div class="social-mini-bar">
            <a href="https://github.com/RaulZamoraPerez" target="_blank" rel="noopener" class="social-link-white" aria-label="GitHub">
