---
import LottiePlayer from './LottiePlayer.jsx';
import codeAnimation from '../assets/animacion/code-animation.json';
---
<section id="contacto">
  <div class="section-container">
    <div class="section-label">
      <span class="label-line"></span>
      <span>Contacto</span>
      <span class="label-line"></span>
    </div>

    <h2 class="section-title">
      Hablemos de tu
      <span class="highlight-text">próximo proyecto</span>
    </h2>
    <p class="section-subtitle">
      Disponible para proyectos freelance, trabajo remoto y nuevas oportunidades. ¡Escríbeme!
    </p>

    <div class="contact-links-row">
      <a href="mailto:raulzamoraperez440@gmail.com" class="contact-icon-btn email" aria-label="Email">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24">
          <rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
        <span class="btn-tooltip">Email</span>
      </a>

      <a href="https://www.linkedin.com/in/raúl-emmanuel-zamora-perez-b94259376" target="_blank" rel="noopener" class="contact-icon-btn linkedin" aria-label="LinkedIn">
        <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        <span class="btn-tooltip">LinkedIn</span>
      </a>

      <a href="https://github.com/RaulZamoraPerez" target="_blank" rel="noopener" class="contact-icon-btn github" aria-label="GitHub">
        <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        <span class="btn-tooltip">GitHub</span>
      </a>

      <a href="https://wa.me/522491698546" target="_blank" rel="noopener" class="contact-icon-btn whatsapp" aria-label="WhatsApp">
        <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        <span class="btn-tooltip">WhatsApp</span>
      </a>
    </div>

    <div class="closing-animation">
      <LottiePlayer 
        client:load 
        animationData={codeAnimation} 
        width="180px" 
        height="180px" 
      />
    </div>

    </div>
  </div>
</section>

<footer class="portfolio-footer">
  <div class="footer-content">
    <span class="footer-logo">
      <span style="color: rgba(255,255,255,0.4)">&lt;</span>Raul<span style="color: var(--cyan)">/</span><span style="color: rgba(255,255,255,0.4)">&gt;</span>
    </span>
    <p class="footer-text">
      Diseñado y construido con ❤️ usando <span style="color: var(--cyan)">Astro</span>
    </p>
    <p class="footer-copy">© 2025 Raul Emmanuel Zamora Perez · Todos los derechos reservados</p>
  </div>
</footer>

<style>
  #contacto {
    padding: 6rem 2rem 4rem;
    position: relative;
    z-index: 1;
  }

  .section-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 1rem;
    text-align: center;
    color: var(--text-primary);
  }

  .highlight-text {
    background: linear-gradient(90deg, var(--cyan), #0099ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-subtitle {
    color: var(--text-secondary);
    font-size: 1rem;
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--cyan);
    justify-content: center;
  }

  .label-line {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--cyan), transparent);
    width: 60px;
  }

  /* Contact Grid */
  .contact-grid {
    display: flex;
    justify-content: center;
    max-width: 1000px;
    margin: 0 auto;
  }

  .contact-cards-container {
    width: 100%;
    max-width: 600px;
  }

  .contact-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.2rem;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    backdrop-filter: blur(20px);
    transition: var(--transition);
    color: var(--text-primary);
    text-decoration: none;
  }

  .contact-card:hover {
    border-color: rgba(0,212,255,0.4);
    transform: translateY(-5px);
    background: var(--glass-hover);
    box-shadow: 0 15px 30px rgba(0,0,0,0.3);
  }

  .contact-card-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    border: 1px solid;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .contact-card-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .contact-card-label {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .contact-card-value {
    font-size: 0.85rem;
    color: #fff;
    font-weight: 600;
    word-break: break-all;
  }

  .contact-arrow {
    color: var(--text-muted);
    transition: var(--transition);
    opacity: 0.5;
  }

  .contact-card:hover .contact-arrow {
    color: var(--cyan);
    transform: translateX(4px);
    opacity: 1;
  }

  /* Footer */
  .portfolio-footer {
    padding: 4rem 2rem;
    border-top: 1px solid var(--glass-border);
    background: radial-gradient(circle at 50% 0%, rgba(0, 212, 255, 0.05) 0%, transparent 70%);
  }

  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
  }

  .footer-logo {
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--cyan);
    margin-bottom: 0.5rem;
  }

  .footer-text {
    font-size: 1rem;
    color: var(--text-secondary);
  }

  .footer-copy {
    font-size: 0.85rem;
    color: var(--text-muted);
    opacity: 0.6;
  }

  .contact-links-row {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-top: 1rem;
    flex-wrap: wrap;
  }

  .contact-icon-btn {
    position: relative;
    width: 65px;
    height: 65px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: white;
    transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    backdrop-filter: blur(10px);
  }

  .contact-icon-btn:hover {
    transform: translateY(-8px);
    border-color: var(--btn-color);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.4), 0 0 20px var(--btn-color-alpha);
    color: var(--btn-color);
  }

  /* Colors */
  .contact-icon-btn.email { --btn-color: #00d4ff; --btn-color-alpha: rgba(0, 212, 255, 0.3); }
  .contact-icon-btn.linkedin { --btn-color: #0a66c2; --btn-color-alpha: rgba(10, 102, 194, 0.3); }
  .contact-icon-btn.github { --btn-color: #ffffff; --btn-color-alpha: rgba(255, 255, 255, 0.2); }
  .contact-icon-btn.whatsapp { --btn-color: #25d366; --btn-color-alpha: rgba(37, 211, 102, 0.3); }

  /* Tooltip */
  .btn-tooltip {
    position: absolute;
    bottom: -35px;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--btn-color);
    opacity: 0;
    transition: all 0.3s ease;
    pointer-events: none;
    white-space: nowrap;
  }

  .contact-icon-btn:hover .btn-tooltip {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  @media (max-width: 650px) {
    .contact-links-row {
      gap: 1.5rem;
    }
    .contact-icon-btn {
      width: 55px;
      height: 55px;
    }
    .closing-animation {
      margin-top: 1rem;
    }
    .closing-animation :global(div) {
      width: 140px !important;
      height: 140px !important;
    }
  }

  /* Closing Animation */
  .closing-animation {
    display: flex;
    justify-content: center;
    margin-top: 1rem;
    opacity: 1;
    transition: transform 0.4s ease;
  }

  .closing-animation:hover {
    transform: scale(1.05);
  }
</style>
