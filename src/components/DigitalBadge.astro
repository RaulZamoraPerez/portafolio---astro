---
// DigitalBadge.astro - A premium interactive ID card/badge
interface Props {
  title: string;
  subtitle: string;
  year: string;
  color?: string;
}

const { title, subtitle, year, color = "#00D4FF" } = Astro.props;
---

<div class="badge-card" style={`--badge-color: ${color}`}>
  <div class="badge-lanyard"></div>
  <div class="badge-content">
    <div class="badge-chip"></div>
    <div class="badge-header">
      <div class="badge-photo">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
        </svg>
      </div>
      <div class="badge-org">RAUL ZAMORA</div>
    </div>
    <div class="badge-body">
      <h3 class="badge-title">{title}</h3>
      <p class="badge-subtitle">{subtitle}</p>
    </div>
    <div class="badge-footer">
      <div class="badge-code">ID-00{year}</div>
      <div class="badge-year">{year}</div>
    </div>
  </div>
</div>

<style>
  .badge-card {
    position: relative;
    width: 260px;
    height: 400px;
    perspective: 1000px;
    cursor: grab;
    margin-top: 40px;
  }

  .badge-lanyard {
    position: absolute;
    top: -60px;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 60px;
    background: linear-gradient(to bottom, #1e293b, var(--badge-color));
    z-index: 0;
  }

  .badge-lanyard::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 20px;
    height: 20px;
    background: #334155;
    border-radius: 4px;
    border: 2px solid var(--badge-color);
  }

  .badge-content {
    width: 100%;
    height: 100%;
    background: linear-gradient(145deg, rgba(30, 41, 59, 0.95) 0%, rgba(15, 23, 42, 0.98) 100%);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(10px);
    transition: transform 0.5s cubic-bezier(0.23, 1, 0.32, 1);
    transform-style: preserve-3d;
    position: relative;
    z-index: 1;
  }

  .badge-card:hover .badge-content {
    transform: rotateY(15deg) rotateX(5deg) scale(1.05);
    border-color: var(--badge-color);
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.6), 0 0 20px var(--badge-color);
  }

  .badge-chip {
    position: absolute;
    top: 24px;
    right: 24px;
    width: 35px;
    height: 25px;
    background: linear-gradient(135deg, #ffd700 0%, #b8860b 100%);
    border-radius: 4px;
    opacity: 0.8;
  }

  .badge-photo {
    width: 80px;
    height: 80px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
    color: var(--badge-color);
  }

  .badge-photo svg { width: 40px; height: 40px; }

  .badge-org {
    font-size: 0.65rem;
    letter-spacing: 0.2rem;
    font-weight: 800;
    color: rgba(255, 255, 255, 0.4);
    text-transform: uppercase;
  }

  .badge-title {
    font-size: 1.1rem;
    font-weight: 800;
    color: white;
    margin-bottom: 8px;
    line-height: 1.2;
  }

  .badge-subtitle {
    font-size: 0.8rem;
    color: var(--badge-color);
    font-weight: 600;
    opacity: 0.8;
  }

  .badge-footer {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 16px;
  }

  .badge-code {
    font-family: 'Fira Code', monospace;
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.2);
  }

  .badge-year {
    font-size: 1.5rem;
    font-weight: 900;
    color: white;
    opacity: 0.1;
  }
</style>
